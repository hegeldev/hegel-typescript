{
  "name": "@antithesishq/hegel-typescript",
  "version": "0.1.0",
  "description": "TypeScript SDK for Hegel property-based testing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antithesishq/hegel-typescript.git"
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write src",
    "test": "tsx --test tests/unit/*.ts",
    "docs": "typedoc"
  },
  "prettier": {
    "semi": false,
    "arrowParens": "avoid",
    "printWidth": 88
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.0.0",
    "typedoc": "^0.28.16",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
