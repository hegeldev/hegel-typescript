{
  "name": "hegel",
  "version": "0.2.5",
  "description": "Hegel property-based testing library for TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --coverage",
    "lint": "prettier --check . && eslint . && tsc --noEmit",
    "format": "prettier --write .",
    "docs": "typedoc"
  },
  "keywords": [
    "hegel",
    "property-based-testing",
    "hypothesis"
  ],
  "author": "David R. MacIver <david.maciver@antithesis.com>",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "cbor-x": "^1.6.0"
  }
}
